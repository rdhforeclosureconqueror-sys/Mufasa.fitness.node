{
  "name": "mufasa-fitness-brain",
  "version": "1.1.0",
  "description": "Mufasa Node fitness brain (fitness domain, exercise DB + command bus)",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "node --watch server.js",
    "build:exercise-index": "node scripts/build-exercise-index.js",
    "prestart": "node scripts/ensure-exercise-index.js",
    "start": "node server.js",
    "lint": "node scripts/selfcheck.js",
    "test": "node --test",
    "pilot:nonsecurity-checks": "node scripts/pilot-nonsecurity-checks.js",
    "performance:audit": "node scripts/performance-audit.js",
    "ops:verify-audit": "node scripts/verify-admin-audit-chain.js",
    "ops:preflight": "node scripts/control-plane-preflight.js",
    "ops:pilot-checks": "node scripts/run-pilot-control-plane-checks.js",
    "diagnostics:routes": "node scripts/diagnostics-routes.js",
    "repo:route-audit": "node scripts/repo-route-audit.js",
    "security:check": "node scripts/security-repository-check.js",
    "test:security": "node --test test/phase12a-security-remediation.test.js test/phase12b-security-assurance.test.js",
    "diagnostics:routes:local": "node scripts/diagnostics-routes-local.js",
    "pilot:readiness:local": "node scripts/pilot-readiness-local.js",
    "security:check": "node --test test/phase12a-security-remediation.test.js",
    "test:security": "node --test test/auth-hardening-phase13.test.js test/phase12a-security-remediation.test.js test/trainer-workspace.test.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "three": "^0.158.0",
    "ws": "^8.18.0"
  },
  "engines": {
    "node": ">=18"
  }
}
