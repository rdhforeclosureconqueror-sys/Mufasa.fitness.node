# Pilot/production auth hardening baseline.
# Copy to .env locally or configure these values in the deployment environment.

# Required: high-entropy token signing secret. Do not use dev/default placeholders.
AUTH_TOKEN_SECRET=replace-with-32-plus-random-characters

# Required: shared pilot login password for POST /api/auth/login.
PILOT_LOGIN_PASSWORD=replace-with-pilot-password

# Required: deterministic pilot login email/principal seed.
LOGIN_SEED_EMAIL=pilot@example.com

# Required in pilot/production: comma-separated browser origins allowed by CORS.
ALLOWED_ORIGINS=https://your-pilot-origin.example

# Required: choose one deterministic super-admin bootstrap allowlist.
AUTHZ_BOOTSTRAP_SUPER_ADMIN_USER_IDS=pilot_email_pilot.example.com
# AUTHZ_BOOTSTRAP_SUPER_ADMIN_SUBJECTS=google:1234567890

# Required hardening toggles. Keep all low-trust/no-auth paths disabled.
ENABLE_TTS_NO_AUTH=false
AUTH_BRIDGE_ALLOW_MANUAL=false
AUTH_BRIDGE_ALLOW_UNVERIFIED_GOOGLE=false
